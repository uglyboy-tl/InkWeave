{
  "name": "inkweave-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "vite": "8.0.3",
      "@vitejs/plugin-react": "6.0.1",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "zustand": "^5.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "vite-plugin-dts": "^4.5.0",
      "esbuild": "^0.28.0"
    }
  },
  "scripts": {
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/web/dist",
    "build": "bun run build:pkg && bun run build:web && bun run build:cli",
    "build:core": "bun -F @inkweave/core build",
    "build:react": "bun -F @inkweave/react build",
    "build:plugins": "bun -F @inkweave/plugins build",
    "build:pkg": "bun run build:core && bun run build:react && bun run build:plugins",
    "build:cli": "bun -F @inkweave/cli build",
    "build:web": "bun -F @inkweave/web build",
    "check": "biome check --write --error-on-warnings . && tsgo -b",
    "test": "bun test && bun test:integration && bun test:e2e",
    "test:e2e": "playwright test",
    "test:integration": "bun -F '*' test:integration",
    "serve": "vite",
    "release": "bun run scripts/release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/bun": "^1.0.10",
    "@tsconfig/vite-react": "7.0.2",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260424.2",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3",
    "vite": "catalog:"
  }
}
