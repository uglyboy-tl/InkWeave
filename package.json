{
  "name": "inkweave-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "vite": "8.0.3",
      "@vitejs/plugin-react": "6.0.1",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "zustand": "^5.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "vite-plugin-dts": "^4.5.0"
    }
  },
  "scripts": {
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/web/dist",
    "build": "bun run build:pkg && bun run build:web",
    "build:core": "bun --cwd packages/core build",
    "build:react": "bun --cwd packages/react build",
    "build:plugins": "bun --cwd packages/plugins build",
    "build:pkg": "bun run build:core && bun run build:react && bun run build:plugins",
    "build:web": "bun --cwd packages/web build",
    "check": "biome check --write --error-on-warnings . && tsgo -b",
    "test": "bun test && bun run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "serve": "vite",
    "release": "bun run scripts/release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@happy-dom/global-registrator": "^20.0.0",
    "@playwright/test": "^1.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@tsconfig/bun": "^1.0.0",
    "@tsconfig/vite-react": "7.0.2",
    "@types/node": "^25.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "bun-types": "^1.0.0",
    "vite": "catalog:"
  }
}
