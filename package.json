{
  "name": "ink-player",
  "version": "1.0.0",
  "description": "A web player for ink interactive fiction",
  "type": "module",
  "main": "./dist/lib.cjs",
  "module": "./dist/lib.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib.js",
      "require": "./dist/lib.cjs"
    },
    "./core": {
      "types": "./dist/lib/core/index.d.ts",
      "import": "./dist/lib/core/index.js",
      "require": "./dist/lib/core/index.cjs"
    },
    "./stores": {
      "types": "./dist/lib/stores/index.d.ts",
      "import": "./dist/lib/stores/index.js",
      "require": "./dist/lib/stores/index.cjs"
    },
    "./features": {
      "types": "./dist/lib/features/index.d.ts",
      "import": "./dist/lib/features/index.js",
      "require": "./dist/lib/features/index.cjs"
    },
    "./components": {
      "types": "./dist/lib/components/index.d.ts",
      "import": "./dist/lib/components/index.js",
      "require": "./dist/lib/components/index.cjs"
    },
    "./web": "./dist/ink-player-web.iife.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "tsc --noEmit && vite build --config vite.lib.config.ts",
    "build:all": "npm run build:lib && npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "game",
    "hugo",
    "react"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "peerDependencies": {
    "inkjs": "^2.3.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-istanbul": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "inkjs": "^2.3.1",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.1",
    "zustand": "^5.0.3"
  }
}