{
  "name": "inkweave-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "bunx prettier --write .",
    "build": "bun run --filter @inkweave/* build",
    "dev": "vite --config examples/vite.config.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test packages/core packages/plugins packages/react"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
