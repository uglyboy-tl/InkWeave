{
  "name": "inkweave-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "typescript": "^5.0.0",
      "vite": "^6.0.0",
      "vite-plugin-dts": "^4.5.4",
      "bun-types": "^1.3.11",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "@testing-library/react": "^16.3.2",
      "@testing-library/jest-dom": "^6.4.0",
      "@vitejs/plugin-react": "^4.4.0",
      "inkjs": "^2.3.1",
      "zustand": "^5.0.3"
    }
  },
  "scripts": {
    "build": "bun run build:pkg && bun run build:web",
    "build:pkg": "bun --cwd packages/core build && bun --cwd packages/react build && bun --cwd packages/plugins build",
    "build:web": "bun --cwd packages/web build",
    "format": "bunx @biomejs/biome format --write .",
    "check": "bunx @biomejs/biome check --write --error-on-warnings . && bunx tsc --noEmit",
    "test": "bun test packages/core packages/plugins packages/react",
    "serve": "vite",
    "release": "bun run scripts/release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/node": "^25.5.0",
    "bun-types": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
