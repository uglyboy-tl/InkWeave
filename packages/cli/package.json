{
  "name": "@inkweave/cli",
  "version": "1.0.0",
  "description": "CLI tool to run Ink story files",
  "type": "module",
  "bin": {
    "inkweave": "./dist/inkweave"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "biome check --write --error-on-warnings . && tsgo --noEmit",
    "build": "bun build --compile --outfile=dist/inkweave src/cli.ts",
    "test:integration": "bun test ./src/__tests__/runner.integration.ts"
  },
  "keywords": [
    "ink",
    "cli",
    "interactive-fiction",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "dependencies": {
    "@inkweave/core": "workspace:*",
    "commander": "catalog:",
    "inkjs": "catalog:",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.2"
  }
}