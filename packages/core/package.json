{
  "name": "@inkweave/core",
  "repository": "https://github.com/uglyboy-tl/InkWeave.git",
  "version": "2.0.2",
  "description": "Core engine for InkWeave - ink story runtime with extension system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "biome check --write --error-on-warnings . && tsgo -b",
    "build": "vite build"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "game-engine",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "peerDependencies": {
    "inkjs": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
