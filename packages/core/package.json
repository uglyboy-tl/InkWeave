{
  "name": "@inkweave/core",
  "repository": "https://github.com/uglyboy-tl/InkWeave.git",
  "version": "1.1.3",
  "description": "Core engine for InkWeave - ink story runtime with extension system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.build.json && vite build",
    "test": "bun test",
    "publish": "npm publish --access public"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "game-engine",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "peerDependencies": {
    "inkjs": "^2.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "inkjs": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "zustand": "catalog:"
  }
}
