=== loop(question)
~ temp option = 0
{get_content(question)}
{ get_question_type(question) == "choice":
+ [{get_option_A(question)}]
	~ option = 1
+ [{get_option_B(question)}]
	~ option = 2
{ get_option_C(question) != "":
+ [{get_option_C(question)}]
	~ option = 3
}
{ get_option_D(question) != "":
+ [{get_option_D(question)}]
	~ option = 4
}
}
{ get_question_type(question) == "judge":
+ [正确]
	~ option = 1
+ [错误]
	~ option = 2
}
-  -> check(question, option) ->
-> loop(get_next_question(question))

== function get_next_question(question)
{
- QUESTION_LIST? question:
	~ QUESTION_LIST -= question
	~ temp random_question = LIST_RANDOM(QUESTION_LIST)
	~ return random_question
- else:
	~ return LIST_RANDOM(QUESTION_LIST)
}

== check(question, option)
#clear
{
	- answer(question) == option:
		~ temp q_score = get_question_score(question)
		~ score += q_score
		答对了！+{q_score}分
	- else:
		答错了!
}
{
- get_question_explanation(question) != "":
	解析：{get_question_explanation(question)}
}
{ check >= max:
	-> 放榜
}
