== function get_option_D(question)
{ question:
{{#each questions}}
{{#if (eq this.type "choice")}}
{{#if this.optionD}}
- q_{{this.id}}:
	~ return "{{{escapeQuotes this.optionD}}}"
{{/if}}
{{/if}}
