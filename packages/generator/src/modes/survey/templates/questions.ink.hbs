== function get_question_score(question)
{ question:
{{#each questions}}
- q_{{this.id}}:
	~ return {{this.score}}
{{/each}}
}

== function get_question_explanation(question)
{ question:
{{#each questions}}
- q_{{this.id}}:
	~ return "{{{escapeQuotes this.explanation}}}"
{{/each}}
}

== function get_answer(question)
{ question:
{{#each questions}}
- q_{{this.id}}:
{{#if (eq this.answer "A")}}
	~ return 1
{{/if}}
{{#if (eq this.answer "B")}}
	~ return 2
{{/if}}
{{#if (eq this.answer "C")}}
	~ return 3
{{/if}}
{{#if (eq this.answer "D")}}
	~ return 4
{{/if}}
{{#if (eq this.answer "true")}}
	~ return 1
{{/if}}
{{#if (eq this.answer "false")}}
	~ return 2
{{/if}}
{{/each}}
}

== function get_question_type(question)
{ question:
{{#each questions}}
- q_{{this.id}}:
	~ return "{{this.type}}"
{{/each}}
}
