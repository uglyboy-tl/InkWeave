LIST QUESTION_LIST = start,{{#each questions}} (q_{{this.id}}){{#unless @last}},{{/unless}}{{/each}}

== function get_content(question)
{ question:
{{#each questions}}
- q_{{this.id}}:
	~ return "{{{escapeQuotes this.content}}}"
{{/each}}
}

== function get_option_A(question)
{ question:
{{#each questions}}
{{#if (eq this.type "choice")}}
- q_{{this.id}}:
	~ return "{{{escapeQuotes this.optionA}}}"
{{/if}}
{{/each}}
}

== function get_option_B(question)
{ question:
{{#each questions}}
{{#if (eq this.type "choice")}}
- q_{{this.id}}:
	~ return "{{{escapeQuotes this.optionB}}}"
{{/if}}
{{/each}}
}

== function get_option_C(question)
{ question:
{{#each questions}}
{{#if (eq this.type "choice")}}
{{#if this.optionC}}
- q_{{this.id}}:
	~ return "{{{escapeQuotes this.optionC}}}"
{{/if}}
{{/if}}
{{/each}}
