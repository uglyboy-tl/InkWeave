{
  "name": "@inkweave/plugins",
  "version": "1.1.1",
  "description": "Optional plugins for InkWeave",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins.css": "./dist/plugins.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.build.json && vite build",
    "test": "bun test",
    "publish": "bun publish --access public"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "plugins",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "peerDependencies": {
    "@inkweave/core": "^1.0.0",
    "@inkweave/react": "^1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "bun-types": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
