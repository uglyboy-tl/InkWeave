{
  "name": "@inkweave/plugins",
  "repository": "https://github.com/uglyboy-tl/InkWeave.git",
  "version": "2.2.0",
  "description": "Plugin collection for InkWeave - extend functionality with plugins",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/src/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./svelte": {
      "types": "./dist/src/svelte/index.d.ts",
      "import": "./dist/svelte/index.js",
      "require": "./dist/svelte/index.cjs"
    },
    "./plugins.css": "./dist/plugins.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "biome check --write --error-on-warnings . && tsgo -b",
    "build": "vite build"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "plugins",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "peerDependencies": {
    "@inkweave/core": "^2.0.0",
    "@inkweave/react": "^2.0.0",
    "@inkweave/svelte": "^2.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "svelte": "^5.0.0",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
