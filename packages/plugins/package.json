{
  "name": "@inkweave/plugins",
  "version": "1.0.1",
  "description": "Optional plugins for InkWeave",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "publish:pkg": "NPM_CONFIG_TOKEN=$(pass show npm/token) bun publish --access public"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "plugins",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "peerDependencies": {
    "@inkweave/core": "^1.0.0",
    "@inkweave/react": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}