{
  "name": "@inkweave/svelte",
  "repository": "https://github.com/uglyboy-tl/InkWeave.git",
  "version": "2.2.0",
  "description": "Svelte components for InkWeave - ready to use in Svelte applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./svelte.css": {
      "default": "./dist/svelte.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "biome check --write --error-on-warnings .",
    "build": "bun scripts/build.ts"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "svelte",
    "components",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "peerDependencies": {
    "@inkweave/core": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "esbuild": "catalog:",
    "esbuild-svelte": "^0.8.0",
    "svelte": "^5.0.0"
  }
}
