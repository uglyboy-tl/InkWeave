{
  "name": "@inkweave/web",
  "version": "1.6.0",
  "description": "Pre-built web bundle for InkWeave - ready to use in browsers via CDN or as an npm module",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/inkweave.min.js",
  "unpkg": "./dist/inkweave.min.js",
  "jsdelivr": "./dist/inkweave.min.js",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "browser": "./dist/inkweave.min.js"
    },
    "./min": "./dist/inkweave.min.js",
    "./inkweave-web.css": "./dist/inkweave.min.css"
  },
  "scripts": {
    "check": "biome check --write --error-on-warnings . && tsgo -b",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "web",
    "cdn",
    "browser",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uglyboy-tl/InkWeave.git"
  },
  "homepage": "https://github.com/uglyboy-tl/InkWeave#readme",
  "dependencies": {
    "@inkweave/core": "^1.0.0",
    "@inkweave/react": "^1.0.0",
    "@inkweave/plugins": "^1.0.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "esbuild": "catalog:",
    "vite": "catalog:"
  }
}
