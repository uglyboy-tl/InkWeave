{
  "name": "@inkweave/web",
  "version": "2.4.1",
  "description": "Pre-built web bundle for InkWeave - ready to use in browsers via CDN or as an npm module",
  "type": "module",
  "main": "./dist/inkweave.min.js",
  "module": "./dist/inkweave.min.js",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "browser": "./dist/inkweave.min.js"
    },
    "./react": {
      "browser": "./dist/inkweave-react.min.js"
    },
    "./svelte": {
      "browser": "./dist/inkweave-svelte.min.js"
    },
    "./solidjs": {
      "browser": "./dist/inkweave-solidjs.min.js"
    },
    "./react.css": "./dist/inkweave-react.min.css",
    "./svelte.css": "./dist/inkweave-svelte.min.css",
    "./solidjs.css": "./dist/inkweave-solidjs.min.css",
    "./global.css": "./dist/inkweave.min.css"
  },
  "scripts": {
    "check": "biome check --write --error-on-warnings . && tsgo -b",
    "dev": "vite",
    "build": "rm -rf dist && vite build --config vite.config.react.ts && vite build --config vite.config.svelte.ts && vite build --config vite.config.solidjs.ts && cp dist/inkweave-solidjs.min.js dist/inkweave.min.js && cp dist/inkweave-solidjs.min.css dist/inkweave.min.css",
    "preview": "vite preview"
  },
  "keywords": [
    "ink",
    "interactive-fiction",
    "web",
    "cdn",
    "browser",
    "inkweave"
  ],
  "author": "Uglyboy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uglyboy-tl/InkWeave.git"
  },
  "homepage": "https://github.com/uglyboy-tl/InkWeave#readme",
  "dependencies": {
    "@inkweave/core": "^2.0.0",
    "@inkweave/react": "^2.0.0",
    "@inkweave/svelte": "^2.0.0",
    "@inkweave/solidjs": "^2.3.0",
    "@inkweave/plugins": "^2.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "svelte": "catalog:",
    "vite": "catalog:",
    "vite-plugin-solid": "catalog:"
  }
}
